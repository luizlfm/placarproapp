rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Cada usuário só escreve no seu próprio espaço.
    // Leitura pública pra que imagens (escudos, fotos, banners) sejam exibidas
    // mesmo em campeonatos públicos.
    match /users/{uid}/{allPaths=**} {
      // Leitura pública
      allow read: if true;

      // Escrita: precisa ter sessão autenticada, ser o dono e tipo válido.
      // Imagens até 25MB, vídeos até 200MB.
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource != null
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size < 25 * 1024 * 1024)
          ||
          (request.resource.contentType.matches('video/.*') && request.resource.size < 200 * 1024 * 1024)
        );

      // Delete livre pro dono
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
